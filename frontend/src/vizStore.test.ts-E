import { describe, it, expect, beforeEach, vi } from "vitest"
import { ALL_ENTITY_TYPES } from "./lib/vizUtils"

// ---------------------------------------------------------------------------
// vizStore unit tests
// Run in Vitest node environment -- localStorage must be stubbed.
// ---------------------------------------------------------------------------

// Minimal localStorage stub before the store module is imported
const localStorageData: Record<string, string> = {}
const localStorageMock = {
  getItem: vi.fn((key: string) => localStorageData[key] ?? null),
  setItem: vi.fn((key: string, value: string) => { localStorageData[key] = value }),
  removeItem: vi.fn((key: string) => { delete localStorageData[key] }),
  clear: vi.fn(() => { for (const k of Object.keys(localStorageData)) delete localStorageData[k] }),
}
vi.stubGlobal("localStorage", localStorageMock)

// Import store AFTER stubbing global so loadActiveTypes() sees the mock
const { useVizStore } = await import("./vizStore")

describe("useVizStore -- selectAllEntityTypes / deselectAllEntityTypes (AC9)", () => {
  beforeEach(() => {
    // Reset to all selected before each test
    useVizStore.getState().selectAllEntityTypes()
  })

  it("selectAllEntityTypes sets activeEntityTypes to all GLiNER entity types", () => {
    // Start from empty
    useVizStore.getState().deselectAllEntityTypes()
    useVizStore.getState().selectAllEntityTypes()
    const active = useVizStore.getState().activeEntityTypes
    for (const type of ALL_ENTITY_TYPES) {
      expect(active.has(type)).toBe(true)
    }
    expect(active.size).toBe(ALL_ENTITY_TYPES.length)
  })

  it("deselectAllEntityTypes clears activeEntityTypes to empty set", () => {
    useVizStore.getState().deselectAllEntityTypes()
    const active = useVizStore.getState().activeEntityTypes
    expect(active.size).toBe(0)
  })

  it("selectAllEntityTypes after deselectAll restores all types", () => {
    useVizStore.getState().deselectAllEntityTypes()
    expect(useVizStore.getState().activeEntityTypes.size).toBe(0)
    useVizStore.getState().selectAllEntityTypes()
    expect(useVizStore.getState().activeEntityTypes.size).toBe(ALL_ENTITY_TYPES.length)
  })

  it("toggleEntityType adds a type when not present", () => {
    useVizStore.getState().deselectAllEntityTypes()
    useVizStore.getState().toggleEntityType("CONCEPT")
    expect(useVizStore.getState().activeEntityTypes.has("CONCEPT")).toBe(true)
    expect(useVizStore.getState().activeEntityTypes.size).toBe(1)
  })

  it("toggleEntityType removes a type when already present", () => {
    useVizStore.getState().selectAllEntityTypes()
    useVizStore.getState().toggleEntityType("CONCEPT")
    expect(useVizStore.getState().activeEntityTypes.has("CONCEPT")).toBe(false)
  })

  it("selectAllEntityTypes persists to localStorage", () => {
    useVizStore.getState().selectAllEntityTypes()
    expect(localStorageMock.setItem).toHaveBeenCalledWith(
      "luminary:vizActiveTypes",
      expect.any(String),
    )
    const stored = JSON.parse(localStorageData["luminary:vizActiveTypes"] ?? "[]") as string[]
    expect(stored.length).toBe(ALL_ENTITY_TYPES.length)
  })

  it("deselectAllEntityTypes persists empty array to localStorage", () => {
    useVizStore.getState().deselectAllEntityTypes()
    const stored = JSON.parse(localStorageData["luminary:vizActiveTypes"] ?? "null") as string[]
    expect(stored).toEqual([])
  })
})
